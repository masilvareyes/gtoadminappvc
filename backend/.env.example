APP_ENV=local
APP_DEBUG=false
APP_NAME=gtosvc-api

# Si Apache sirve el proyecto bajo un prefijo (Alias), colócalo aquí. Ej: /gtosVC2ok
APP_BASE_PATH=

# Solo desarrollo: permite registrar GET /api/debug/exception (lanza error para probar JSON 500)
GTV_ALLOW_EXCEPTION_TEST=false

# Base de datos (BL-003)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=gtosvc
DB_USER=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
